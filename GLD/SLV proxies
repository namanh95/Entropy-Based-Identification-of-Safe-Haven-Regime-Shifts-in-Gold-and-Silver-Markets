def compute_lead_lag_events(df, asset, q_star):
    qcol = f"q_{asset}"
    rcol = f"rhoL_{asset}"

    tmp = df[[qcol, rcol]].dropna().copy()

    # Find upward crossings
    q_cross = (tmp[qcol] > q_star) & (tmp[qcol].shift(1) <= q_star)
    r_cross = (tmp[rcol] > 0) & (tmp[rcol].shift(1) <= 0)

    q_times = tmp.index[q_cross]
    r_times = tmp.index[r_cross]

    if len(q_times) == 0 or len(r_times) == 0:
        return np.nan

    lead_lags = []

    for tq in q_times:
        future_r = r_times[r_times >= tq]
        if len(future_r) > 0:
            tr = future_r[0]
            lead_lags.append((tr - tq).days)

    if len(lead_lags) == 0:
        return np.nan

    return np.mean(lead_lags)
