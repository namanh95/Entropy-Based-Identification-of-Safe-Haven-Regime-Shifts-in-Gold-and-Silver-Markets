tickers = ["GLD", "SLV", "SPY"]
raw = yf.download(
    tickers,
    start="2005-01-01",
    auto_adjust=True,
    progress=False,
    group_by="column"
)

if isinstance(raw.columns, pd.MultiIndex):
    prices = raw["Close"].dropna()
else:
    prices = raw[["Close"]].rename(columns={"Close": tickers[0]}).dropna()

assert prices.shape[1] == len(tickers), f"Unexpected columns: {prices.columns}"

rets = np.log(prices).diff().dropna()

# ----------------------------
# 2) q-Gaussian log-likelihood
# ----------------------------
def log_Zq(q, beta):
    a = (3.0 - q) / (2.0 * (q - 1.0))
    b = 1.0 / (q - 1.0)
    return 0.5 * np.log(np.pi) + gammaln(a) - 0.5 * np.log(beta * (q - 1.0)) - gammaln(b)

def neg_loglik(params, x):
    q, beta = params
    if not (1.0001 < q < 2.9999 and beta > 1e-12):
        return 1e12
    logZ = log_Zq(q, beta)
    term = 1.0 + (q - 1.0) * beta * (x ** 2)
    ll = -logZ - (1.0 / (q - 1.0)) * np.log(term)
    return -np.sum(ll)

def fit_q_gaussian(x):
    x = np.asarray(x)
    x = (x - x.mean()) / (x.std() + 1e-12)
    x0 = np.array([1.25, 1.0])
    bounds = [(1.0001, 2.9999), (1e-6, 100.0)]
    res = minimize(neg_loglik, x0, args=(x,), method="L-BFGS-B", bounds=bounds)
    return res.x[0], res.x[1]

# ----------------------------
# 3) Rolling q estimation
# ----------------------------
W = 252
dates = rets.index[W:]
roll_q = {"GLD": [], "SLV": []}

for i in range(W, len(rets)):
    window = rets.iloc[i - W:i]
    for t in ["GLD", "SLV"]:
        q_hat, _ = fit_q_gaussian(window[t].values)
        roll_q[t].append(q_hat)

roll_q_df = pd.DataFrame(roll_q, index=dates)

# ----------------------------
# 4) Rolling lower-tail correlation with SPY
# ----------------------------
def lower_tail_corr(x, y, quantile=0.05):
    x = np.asarray(x)
    y = np.asarray(y)
    thresh = np.quantile(y, quantile)   # lower tail of market return
    mask = y <= thresh
    if mask.sum() < 10:
        return np.nan
    xs = x[mask]
    ys = y[mask]
    if np.std(xs) < 1e-12 or np.std(ys) < 1e-12:
        return np.nan
    return np.corrcoef(xs, ys)[0, 1]

roll_tailcorr = {"GLD": [], "SLV": []}

for i in range(W, len(rets)):
    window = rets.iloc[i - W:i]
    spy_w = window["SPY"].values
    for t in ["GLD", "SLV"]:
        asset_w = window[t].values
        rho_L = lower_tail_corr(asset_w, spy_w, quantile=0.05)
        roll_tailcorr[t].append(rho_L)

roll_tailcorr_df = pd.DataFrame(roll_tailcorr, index=dates)

